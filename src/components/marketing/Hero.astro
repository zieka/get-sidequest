---
import VillageCanvas from '../village/VillageCanvas';
const base = import.meta.env.BASE_URL;
const downloadUrl = "https://github.com/zieka/get-sidequest/releases/latest";
const docsUrl = `${base}docs/`;
---

<section class="relative overflow-hidden h-screen min-h-[600px] max-h-[900px]">
  <!-- Three.js Canvas -->
  <VillageCanvas client:only="react" />

  <!-- Dark gradient overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent pointer-events-none"></div>

  <!-- Text overlay -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full px-6 text-center">
    <h1 class="font-heading text-4xl md:text-6xl tracking-tight leading-[1.15] mb-6 hero-text">
      Your main quest is always running.<br />
      But every great adventure needs
      <span class="hero-stroke-text">sidequests.</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed hero-text">
      Orchestrate multiple parallel agents to tackle bugs, ship features, and research solutions, because sometimes it takes a village.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={downloadUrl} class="inline-flex items-center px-6 py-3 rounded-xl text-base font-medium text-white bg-gradient-to-r from-accent to-cyan-400 hover:opacity-90 transition-opacity shadow-lg shadow-accent/25">
        Download for macOS
      </a>
      <a href={docsUrl} class="inline-flex items-center px-6 py-3 rounded-xl text-base font-medium text-gray-300 border border-white/10 hover:border-white/20 hover:text-white transition-all">
        Read the docs
      </a>
    </div>
  </div>
</section>

<style>
  .hero-text {
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8), 0 4px 24px rgba(0, 0, 0, 0.6);
  }
  .hero-stroke-text {
    color: white;
    position: relative;
    -webkit-text-stroke: 1.5px transparent;
    background: linear-gradient(90deg, #a78bfa, #7c3aed, #38bdf8, #a78bfa);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradient-shift 4s linear infinite;
    paint-order: stroke fill;
    -webkit-text-stroke: 2px;
    -webkit-text-stroke-color: transparent;
    text-shadow: none;
  }
  .hero-stroke-text::before {
    content: 'sidequests.';
    position: absolute;
    left: 0;
    top: 0;
    -webkit-text-fill-color: white;
    -webkit-text-stroke: 0;
    z-index: -1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8), 0 4px 24px rgba(0, 0, 0, 0.6);
  }
  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }
</style>
