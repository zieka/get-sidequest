---
interface Props {
  headline: string;
  description: string;
  screenshotLabel: string;
  screenshotDescription: string;
  reverse?: boolean;
  icon?: string;
}

const { headline, description, screenshotLabel, screenshotDescription, reverse = false, icon } = Astro.props;
const base = import.meta.env.BASE_URL;

// Text rotates inward toward the screenshot, screenshot rotates inward toward text
const textRotate = reverse ? 'rotateY(-3deg)' : 'rotateY(3deg)';
const screenshotRotate = reverse ? 'rotateY(3deg)' : 'rotateY(-3deg)';
---

<div class={`flex flex-col ${reverse ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-12 py-16`} style="perspective: 1200px;">
  <!-- Text -->
  <div class="flex-1 text-center md:text-left" style={`transform: ${textRotate}; transform-style: preserve-3d;`}>
    <div class="flex items-center gap-3 justify-center md:justify-start mb-4">
      {icon && <img src={`${base}${icon}`} alt="" class="w-10 h-10" style="image-rendering: pixelated;" />}
      <h3 class="font-heading text-2xl md:text-3xl tracking-tight">{headline}</h3>
    </div>
    <p class="text-lg text-gray-400 leading-relaxed">{description}</p>
  </div>

  <!-- Screenshot placeholder -->
  <div class="flex-1 w-full" style={`transform: ${screenshotRotate}; transform-style: preserve-3d;`}>
    <div class="relative">
      <div class="absolute -inset-2 bg-gradient-to-r from-accent/10 to-cyan-400/10 rounded-xl blur-xl" />
      <div class="relative rounded-xl border border-white/10 bg-surface overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5">
          <div class="w-2.5 h-2.5 rounded-full bg-red-500/50" />
          <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50" />
          <div class="w-2.5 h-2.5 rounded-full bg-green-500/50" />
        </div>
        <div class="aspect-[16/10] flex items-center justify-center p-6 text-gray-500 border-2 border-dashed border-white/5 m-3 rounded-lg">
          <div class="text-center">
            <p class="text-sm font-mono mb-2">[SCREENSHOT: {screenshotLabel}]</p>
            <p class="text-xs max-w-sm">{screenshotDescription}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
