---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Navbar from '../components/marketing/Navbar.astro';
import Hero from '../components/marketing/Hero.astro';
import Problem from '../components/marketing/Problem.astro';
import Features from '../components/marketing/Features.astro';
import FeatureGrid from '../components/marketing/FeatureGrid.astro';
import DownloadCTA from '../components/marketing/DownloadCTA.astro';
import Footer from '../components/marketing/Footer.astro';
---

<MarketingLayout
  title="Sidequest — Your AI development team, orchestrated."
  description="Run parallel Claude Code agents, supervise them automatically, and ship faster than ever."
>
  <Navbar />
  <main class="pt-16">
    <Hero />
    <Problem />
    <section class="relative px-6 pt-24 pb-4">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-mono text-accent mb-4 tracking-widest uppercase">The solution</p>
      </div>
    </section>
    <section class="relative px-6 pb-24">
      <div class="mx-auto max-w-5xl">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-r from-accent/20 to-cyan-400/20 rounded-2xl blur-2xl" />
          <img src={`${import.meta.env.BASE_URL}screenshots/sidequest.png`} alt="Sidequest" class="relative rounded-xl border border-white/10 shadow-2xl w-full" />
        </div>
        <p class="text-center text-sm text-gray-400 mt-6">The next generation of IDE for commanding your agentic team.</p>
      </div>
    </section>
    <Features />
    <FeatureGrid />
    <DownloadCTA />
  </main>
  <Footer />
</MarketingLayout>
